# Copy to .env and fill in values.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Used in welcome emails and trial signup links (no trailing slash)
FRONTEND_URL=https://cleanflow.harbix.app

# Resend — https://resend.com (trial welcome + owner login details)
# Verify your domain in Resend, then set e.g. CleanFlow <noreply@yourdomain.com>
RESEND_API_KEY=
EMAIL_FROM=

# Internal tooling only (POST /api/internal/create-trial-account)
INTERNAL_API_SECRET=
